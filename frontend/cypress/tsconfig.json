{
  "compilerOptions": {
    "target": "es5",
    "lib": ["es5", "dom"],
    "types": ["cypress", "node"],
    "downlevelIteration": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["**/*.cy.ts", "support/**/*.ts", "fixtures/**/*.json"]
}